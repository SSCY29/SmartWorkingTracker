<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SmartWorkingTracker.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SmartWorkingTracker.App"
    xmlns:pages="clr-namespace:SmartWorkingTracker.App.Pages"
    Title="Smart Working Tracker">

    <!-- DASHBOARD -->
    <ShellItem Title="Dashboard" Route="dashboard">
        <ShellContent
            Title="Riepilogo"
            Icon="dashboard.png"
            ContentTemplate="{DataTemplate pages:MainPage}" />
    </ShellItem>

    <!-- GESTIONE -->
    <ShellItem Title="Gestione" Route="management">
        <ShellContent
            Title="Aggiungi sessione"
            Icon="add.png"
            ContentTemplate="{DataTemplate pages:WorkSessionEditorPage}" />
    </ShellItem>

    <!-- ANALISI -->
    <ShellItem Title="Statistiche" Route="statistics">
        <ShellContent
            Title="Statistiche"
            Icon="chart.png"
            ContentTemplate="{DataTemplate pages:StatisticsPage}" />
    </ShellItem>

    <ShellItem Title="Report" Route="report">
        <ShellContent
            Title="Report"
            Icon="report.png"
            ContentTemplate="{DataTemplate pages:ReportPage}" />
    </ShellItem>

</Shell>
