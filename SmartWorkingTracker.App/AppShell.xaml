<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SmartWorkingTracker.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SmartWorkingTracker.App"
    xmlns:pages="clr-namespace:SmartWorkingTracker.App.Pages"
    Title="Smart Working Tracker">

    <!-- ✅ HOME -->
    <ShellItem Title="Home" Route="home">
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate pages:MainPage}" />
    </ShellItem>

    <!-- ✅ CONTRATTI -->
    <ShellItem Title="Contratti" Route="contracts">
        <ShellContent
            Title="Contratti"
            ContentTemplate="{DataTemplate pages:ContractPage}" />
    </ShellItem>

    <!-- ✅ REPORT -->
    <ShellItem Title="Report">
        <ShellContent
            Title="Report"
            ContentTemplate="{DataTemplate pages:ReportPage}" />
    </ShellItem>

</Shell>
