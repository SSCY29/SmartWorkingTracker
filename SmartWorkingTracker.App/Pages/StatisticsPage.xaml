<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartWorkingTracker.App.Pages.StatisticsPage"
             xmlns:charts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             Title="Statistiche">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="24">

            <Label
                Text="Statistiche di lavoro"
                FontSize="20"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <!-- Grafico 1: Presenza vs Smart Working -->
            <Label
                Text="Distribuzione ore (mese)"
                FontAttributes="Bold" />

            <charts:ChartView
                HeightRequest="200"
                Chart="{Binding PresenceVsSmartChart}" />

            <!-- Grafico 2: Settimana -->
            <Label
                Text="Ore settimanali"
                FontAttributes="Bold" />

            <charts:ChartView
                HeightRequest="200"
                Chart="{Binding WeeklyChart}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>