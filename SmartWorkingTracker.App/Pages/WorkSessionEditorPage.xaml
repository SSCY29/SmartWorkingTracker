<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartWorkingTracker.App.Pages.WorkSessionEditorPage"
             Title="Aggiungi sessione"         
             xmlns:converters="clr-namespace:SmartWorkingTracker.App.Converters">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <ScrollView>
            <VerticalStackLayout Padding="20"
                                 Spacing="16">

                <Label
                Text="Nuova sessione di lavoro"
                FontSize="20"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

                <!-- Data -->
                <DatePicker
                Date="{Binding SessionDate}" />

                <!-- Orari -->
                <Label Text="Inizio" />
                <TimePicker
                Time="{Binding StartTime}" />

                <Label Text="Fine" />
                <TimePicker
                Time="{Binding EndTime}" />

                <!-- Tipo sessione -->
                <Label Text="Tipo" />
                <Picker
                ItemsSource="{Binding SessionTypes}"
                SelectedItem="{Binding SelectedSessionType}" />

                <!-- Note -->
                <Label Text="Note (opzionale)" />
                <Editor
                Text="{Binding Notes}"
                AutoSize="TextChanges"
                Placeholder="Inserisci note..." />

                <!-- Salva -->
                <Button
                Text="Salva sessione"
                Command="{Binding SaveCommand}"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

                <!-- Loading -->
                <ActivityIndicator
                IsVisible="{Binding IsBusy}"
                IsRunning="{Binding IsBusy}"
                HorizontalOptions="Center" />

                <!-- Errore -->
                <Label
                Text="{Binding ErrorMessage}"
                TextColor="Red"
                IsVisible="{Binding HasError}" />

            </VerticalStackLayout>
        </ScrollView>
</ContentPage>
