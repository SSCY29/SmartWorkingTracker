<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartWorkingTracker.App.Pages.EditSessionPage"
             xmlns:converters="clr-namespace:SmartWorkingTracker.App.Converters"
             Title="Edit Session">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <VerticalStackLayout Padding="20" Spacing="12">

        <Label Text="Tipo sessione" FontAttributes="Bold" />
        <Picker ItemsSource="{Binding SessionTypes}"
                SelectedItem="{Binding SessionType}" />

        <Label Text="Data" />
        <DatePicker Date="{Binding Day}" />
        
        <Label Text="Inizio" />        
        <TimePicker Time="{Binding StartTime}" />

        <Label Text="Fine" />        
        <TimePicker Time="{Binding EndTime}" />

        <Label Text="Note" />
        <Editor Text="{Binding Notes}" />

        <Button
            Text="Salva modifiche"
            Command="{Binding SaveCommand}"
            IsEnabled="{Binding IsBusy,
                Converter={StaticResource InverseBoolConverter}}" />

        <Button
            Text="Elimina sessione"
            BackgroundColor="DarkRed"
            TextColor="White"
            Command="{Binding DeleteCommand}"
            IsEnabled="{Binding IsBusy,
                Converter={StaticResource InverseBoolConverter}}" />

    </VerticalStackLayout>
</ContentPage>