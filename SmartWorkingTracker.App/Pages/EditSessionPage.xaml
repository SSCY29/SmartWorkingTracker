<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartWorkingTracker.App.Pages.EditSessionPage"
             Title="Sessione">


    <VerticalStackLayout Padding="20" Spacing="10">

        <!-- ORA INIZIO -->
        <Label Text="Ora iniziale" />
        <TimePicker Time="{Binding StartTime}" />

        <!-- ORA FINE -->
        <Label Text="Ora fine" />
        <TimePicker Time="{Binding EndTime}" />

        <!-- TIPO -->
        <Label Text="Tipo sessione" />
        <Picker SelectedIndex="{Binding TypeIndex}">
            <Picker.Items>
                <x:String>Presenza</x:String>
                <x:String>SmartWorking</x:String>
                <x:String>NonPresente</x:String>
            </Picker.Items>
        </Picker>

        <!-- NOTE -->
        <Label Text="Note" />
        <Editor Text="{Binding Notes}" HeightRequest="80" />

        <!-- SALVA -->
        <Button Text="Salva"
                Clicked="OnSaveClicked" />

    </VerticalStackLayout>


</ContentPage>