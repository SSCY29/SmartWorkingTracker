<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartWorkingTracker.App.Pages.SessionListPage"
             xmlns:Models="clr-namespace:SmartWorkingTracker.Core.Models;assembly=SmartWorkingTracker.Core"
             Title="Lista Sessioni"
                      xmlns:converters="clr-namespace:SmartWorkingTracker.App.Converters">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>

        <VerticalStackLayout Spacing="10" Padding="10" IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">

            <!-- HEADER -->
            <Label Text="{Binding Date, StringFormat='Sessioni del {0:dd/MM/yyyy}'}"
               FontSize="18"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

            <!-- ADD BUTTON -->
            <Button Text="➕ Nuova sessione"
                Clicked="OnAddClicked" />

            <!-- LISTA SESSIONI -->
            <CollectionView ItemsSource="{Binding Sessions}">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="Models:WorkSession">

                        <Border Padding="10"
                            Margin="5"
                            Stroke="Gray"
                            StrokeThickness="1">


                            <Grid ColumnDefinitions="*,Auto">

                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding Type}" />
                                    <Label Text="{Binding StartDate, StringFormat='{0:HH:mm}'}"/>
                                </VerticalStackLayout>

                                <HorizontalStackLayout Grid.Column="1" Spacing="5">

                                    <Button Text="✏"
                                        WidthRequest="40"
                                        CommandParameter="{Binding}"
                                        Clicked="OnEditClicked"/>
                                    <Button Text="🗑"
                                        WidthRequest="40"
                                        CommandParameter="{Binding}"
                                        Clicked="OnDeleteClicked"/>

                                </HorizontalStackLayout>

                            </Grid>


                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>
        <Grid IsVisible="{Binding IsLoading}">
            <VerticalStackLayout VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="10">

                <ActivityIndicator
            IsRunning="True" />

                <Label Text="Caricamento..."  HorizontalOptions="Center" />

            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>