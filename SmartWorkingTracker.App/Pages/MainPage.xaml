<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartWorkingTracker.App.Pages.MainPage"
             xmlns:viewModels="clr-namespace:SmartWorkingTracker.App.ViewModels"
             xmlns:converters="clr-namespace:SmartWorkingTracker.App.Converters">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>



    <Grid>

        <VerticalStackLayout Spacing="10" Padding="10" IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">

            <Label Text="Calendario Smart Working"
               FontSize="20"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Picker ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}" />

                <Button Text="Aggiorna" Clicked="OnReloadClicked" Grid.Column="1"/>
            </Grid>



            <Grid ColumnDefinitions="Auto,*,Auto">

                <Button Text="Precedente" 
                        Clicked="OnPrevMonth" 
                        Grid.Column="0" />

                <Label Text="{Binding CurrentPeriod}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"  
                       Grid.Column="1"/>

                <Button Text="Successivo"
                        Clicked="OnNextMonth"
                        Grid.Column="2" />

            </Grid>


            <VerticalStackLayout>

                <CollectionView ItemsSource="{Binding WeekDays}">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="7"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="3">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>

                                <Grid HeightRequest="50" BackgroundColor="{AppThemeBinding Light={StaticResource WeekendColorLight}, Dark={StaticResource WeekendColorDark}}">
                                    <Label Text="{Binding}" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>


                <CollectionView ItemsSource="{Binding Days}" VerticalScrollBarVisibility="Never" HorizontalScrollBarVisibility="Never">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="7" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:DayViewModel">
                            <Border Margin="3"
                                Padding="5"
                                BackgroundColor="{Binding Color}"
                                StrokeThickness="1"
                                Stroke="Gray">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>


                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer CommandParameter="{Binding Date}"
                                                      Tapped="OnDayTapped" />
                                </Border.GestureRecognizers>


                                <Grid HeightRequest="40">

                                    <Label Text="{Binding Display}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Start" />

                                    <Label Text="{Binding Summary}"
                                       FontSize="10"
                                       HorizontalOptions="End"
                                       VerticalOptions="End" />
                                </Grid>


                            </Border>


                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
            <Label Text="⚠ Nessun contratto per l'anno selezionato"
                   TextColor="Red"
                   IsVisible="{Binding ContractMissing}"
                   FontSize="15"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"/>
            <!-- LEGENDA -->

            <Border Stroke="LightGray"
            StrokeThickness="1"
            Padding="5"
            Margin="5">

                <VerticalStackLayout Spacing="8">

                    <Label Text="Legenda"
                   FontAttributes="Bold"
                   FontSize="16"/>

                    <!-- Riga 1 -->
                    <Grid ColumnDefinitions="*,*">

                        <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="5">
                            <BoxView WidthRequest="15" HeightRequest="15" BackgroundColor="{AppThemeBinding Light={StaticResource SwColorLight}, Dark={StaticResource SwColorDark}}"/>
                            <Label Text="Smart Working"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="5">
                            <BoxView WidthRequest="15" HeightRequest="15" BackgroundColor="{AppThemeBinding Light={StaticResource PresenceColorLight}, Dark={StaticResource PresenceColorDark}}"/>
                            <Label Text="Presenza"/>
                        </HorizontalStackLayout>
                    </Grid>
                    <!-- Riga 2 -->
                    <Grid ColumnDefinitions="*,*">

                        <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="5" >
                            <BoxView WidthRequest="15" HeightRequest="15" BackgroundColor="{AppThemeBinding Light={StaticResource AbsentColorLight}, Dark={StaticResource AbsentColorDark}}"/>
                            <Label Text="Assente"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="5" >
                            <BoxView WidthRequest="15" HeightRequest="15" BackgroundColor="{AppThemeBinding Light={StaticResource MixedColorLight}, Dark={StaticResource MixedColorDark}}"/>
                            <Label Text="Misto"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*">
                        <!-- Riga 3 -->
                        <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Spacing="5">
                            <BoxView WidthRequest="15" HeightRequest="15" BackgroundColor="{AppThemeBinding Light={StaticResource WeekendColorLight}, Dark={StaticResource WeekendColorDark}}"/>
                            <Label Text="Weekend"/>
                        </HorizontalStackLayout>

                    </Grid>

                    <Label Text="Tocca un giorno per modificare le sessioni"  HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </Border>
        </VerticalStackLayout>


        <Grid IsVisible="{Binding IsLoading}">
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="10">

                <ActivityIndicator
                IsRunning="True" />

                <Label Text="Caricamento..."  HorizontalOptions="Center" />

            </VerticalStackLayout>

        </Grid>

    </Grid>

</ContentPage>