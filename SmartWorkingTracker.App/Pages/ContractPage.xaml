<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartWorkingTracker.App.Pages.ContractPage"
             Title="Contratti">

    <VerticalStackLayout Padding="10">

        <Button Text="➕ Nuovo Contratto"
                Clicked="OnAddClicked"/>

        <CollectionView ItemsSource="{Binding Contracts}">
            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border Padding="10" Margin="5">
                        <VerticalStackLayout>

                            <Label Text="{Binding Year}" FontAttributes="Bold"/>
                            <Label Text="{Binding MonthlyLimitHours, StringFormat='Mensile: {0}h'}"/>

                            <HorizontalStackLayout Spacing="10">

                                <Button Text="Modifica"
                                        Clicked="OnEditClicked"
                                        CommandParameter="{Binding}" />

                                <Button Text="Elimina"
                                        Clicked="OnDeleteClicked"
                                        CommandParameter="{Binding}" />

                            </HorizontalStackLayout>

                        </VerticalStackLayout>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>